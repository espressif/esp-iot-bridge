diff --git a/src/core/ipv4/dhcp.c b/src/core/ipv4/dhcp.c
index cacf555d..3a9409c8 100644
--- a/src/core/ipv4/dhcp.c
+++ b/src/core/ipv4/dhcp.c
@@ -282,6 +282,12 @@ static u16_t dhcp_option_hostname(u16_t options_out_len, u8_t *options, struct n
 /* always add the DHCP options trailer to end and pad */
 static void dhcp_option_trailer(u16_t options_out_len, u8_t *options, struct pbuf *p_out);
 
+__attribute__((weak)) void dhcp_dns_update_customer_cb(struct netif *netif, void *param)
+{
+  LWIP_UNUSED_ARG(netif);
+  LWIP_UNUSED_ARG(param);
+}
+
 /** Ensure DHCP PCB is allocated and bound */
 static err_t
 dhcp_inc_pcb_refcount(void)
@@ -799,6 +805,7 @@ dhcp_handle_ack(struct netif *netif, struct dhcp_msg *msg_in)
 
 #if LWIP_DHCP_PROVIDE_DNS_SERVERS
   /* DNS servers */
+  bool changed = false;
   for (n = 0; (n < LWIP_DHCP_PROVIDE_DNS_SERVERS) && dhcp_option_given(dhcp, DHCP_OPTION_IDX_DNS_SERVER + n); n++) {
     ip_addr_t dns_addr;
 #if ESP_DNS
@@ -806,13 +813,22 @@ dhcp_handle_ack(struct netif *netif, struct dhcp_msg *msg_in)
         continue;
     }
 #endif
